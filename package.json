{
  "name": "atlas-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development next dev --turbopack",
    "build": "NODE_ENV=production next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml,mjs,cjs}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "DEBUG_LOGGING=1 vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "npx --yes tsc --noEmit --skipLibCheck --project tsconfig.json",
    "ngrok": "ngrok http 3000",
    "prepare": "husky && husky install"
  },
  "dependencies": {
    "@heroui/react": "^2.8.5",
    "@heroui/use-clipboard": "^2.1.9",
    "@vercel/analytics": "^1.5.0",
    "archiver": "^7.0.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.23.12",
    "highlight.js": "^11.11.1",
    "highlightjs-solidity": "^2.0.6",
    "katex": "^0.16.25",
    "lucide-react": "^0.542.0",
    "markdown-it": "^14.1.0",
    "next": "^16.0.10",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.3.1",
    "tar": "^7.5.13",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@actions/core": "^1.11.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/archiver": "^7.0.0",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.6",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/tar": "^6.1.13",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.2.6",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "postcss": "^8.5.10",
    "undici": "^6.24.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
